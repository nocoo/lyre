{
  "name": "lyre",
  "version": "1.6.5",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run web:dev",
    "build": "bun run web:build",
    "lint": "bun run web:lint && bun run api:lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "bun run web:typecheck && bun run worker:typecheck && bun run api:typecheck",
    "deploy": "bun run web:build && bun run --cwd apps/api deploy",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "web:lint": "bun run --cwd apps/web lint",
    "web:typecheck": "bun run --cwd apps/web typecheck",
    "worker:dev": "bun run --cwd apps/api dev",
    "worker:typecheck": "bun run --cwd apps/api typecheck",
    "api:lint": "bun run --cwd packages/api lint",
    "api:typecheck": "bun run --cwd packages/api typecheck",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "gate:routes": "bun run scripts/check-route-coverage.ts",
    "gate:secrets": "bun run scripts/gate-secrets.ts",
    "gate:deps": "bun run scripts/gate-deps.ts",
    "prepare": "husky",
    "release": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^12.9.0",
    "husky": "^9.1.7",
    "vitest": "^4.1.5"
  }
}
