# pre-push: L1 (Coverage) + G1 (Lint) + L2 (E2E) + G2b (Deps)
set -e

# G2b: Dependency vulnerability scanning
if command -v osv-scanner &>/dev/null; then
  [ -f bun.lock ] && osv-scanner scan --lockfile=bun.lock --config=osv-scanner.toml
else
  echo "❌ osv-scanner not installed — install: brew install osv-scanner" >&2
  exit 1
fi

# Web (legacy): coverage + lint + build + e2e
# During the CF Worker migration (docs/03-cf-worker-migration-plan.md) only
# legacy paths run here. Add new-package hooks once apps/web + apps/api ship.
bun run legacy:test:coverage && bun run legacy:lint && bun run legacy:build && bun run legacy:test:e2e

# macOS: unit tests + lint (E2E included in LyreTests scheme)
cd apps/macos && \
  xcodebuild test -project Lyre.xcodeproj -scheme LyreTests -configuration Debug -destination "platform=macOS" -quiet && \
  swiftlint lint --strict Lyre/ LyreTests/
