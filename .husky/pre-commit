# pre-commit: secrets scan + lint + UT + typecheck (web, worker, @lyre/api, macOS)
set -e

# Secrets scanning (must run before any other check)
if command -v gitleaks &>/dev/null; then
  gitleaks protect --staged --no-banner
else
  echo "❌ gitleaks not installed — install: brew install gitleaks" >&2
  exit 1
fi

bun run lint
bun run test
bun run typecheck

# macOS: unit tests + lint
cd apps/macos && \
  xcodebuild test -project Lyre.xcodeproj -scheme LyreTests -configuration Debug -destination "platform=macOS" -quiet && \
  swiftlint lint --strict Lyre/ LyreTests/
